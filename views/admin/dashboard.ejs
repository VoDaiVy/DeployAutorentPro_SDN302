<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - AutoRent Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="admin-container">
    
    <div class="sidebar">
        <div class="brand">
            <i class="fas fa-car-tunnel me-2"></i> AUTORENT ADMIN
        </div>
        <ul class="sidebar-menu">
            <li>
                <a href="/admin/dashboard" class="active">
                    <i class="fas fa-th-large"></i> Tổng quan
                </a>
            </li>
            <li>
                <a href="/admin/bookings">
                    <i class="fas fa-file-invoice-dollar"></i> Quản lý đơn đặt
                    <% if(stats.pendingCount > 0) { %>
                        <span class="badge bg-danger ms-2 rounded-pill"><%= stats.pendingCount %></span>
                    <% } %>
                </a>
            </li>
            <li>
                <a href="/cars">
                    <i class="fas fa-car"></i> Quản lý xe
                </a>
            </li>
            <li class="mt-4 border-top border-secondary pt-2">
                <a href="/" target="_blank">
                    <i class="fas fa-external-link-alt"></i> Xem Website
                </a>
            </li>
            <li>
                <a href="/auth/logout" class="text-danger">
                    <i class="fas fa-sign-out-alt"></i> Đăng xuất
                </a>
            </li>
        </ul>
    </div>

    <div class="main-content">
        
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h3 class="fw-bold m-0">Dashboard</h3>
                <p class="text-muted m-0">Chào mừng trở lại, Admin!</p>
            </div>
            <div class="d-flex align-items-center">
                <div class="bg-white p-2 rounded shadow-sm px-3">
                    <i class="fas fa-calendar-alt text-primary me-2"></i>
                    <%= new Date().toLocaleDateString('vi-VN') %>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="stats-card">
                    <div>
                        <h6 class="text-muted text-uppercase mb-2" style="font-size: 0.8rem;">Tổng doanh thu</h6>
                        <h4 class="fw-bold text-success mb-0"><%= stats.revenue.toLocaleString('vi-VN') %> đ</h4>
                    </div>
                    <div class="stats-icon bg-success bg-opacity-10 text-success">
                        <i class="fas fa-wallet"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stats-card">
                    <div>
                        <h6 class="text-muted text-uppercase mb-2" style="font-size: 0.8rem;">Tổng đơn hàng</h6>
                        <h4 class="fw-bold text-primary mb-0"><%= stats.totalBookings %></h4>
                    </div>
                    <div class="stats-icon bg-primary bg-opacity-10 text-primary">
                        <i class="fas fa-shopping-bag"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stats-card">
                    <div>
                        <h6 class="text-muted text-uppercase mb-2" style="font-size: 0.8rem;">Tổng số xe</h6>
                        <h4 class="fw-bold text-info mb-0"><%= stats.totalCars %></h4>
                    </div>
                    <div class="stats-icon bg-info bg-opacity-10 text-info">
                        <i class="fas fa-car"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stats-card">
                    <div>
                        <h6 class="text-muted text-uppercase mb-2" style="font-size: 0.8rem;">Cần xử lý</h6>
                        <h4 class="fw-bold text-danger mb-0"><%= stats.pendingCount %> đơn</h4>
                    </div>
                    <div class="stats-icon bg-danger bg-opacity-10 text-danger">
                        <i class="fas fa-bell"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold m-0"><i class="fas fa-clock me-2 text-warning"></i>Đơn đặt xe mới nhất</h6>
                <a href="/admin/bookings" class="btn btn-sm btn-outline-primary rounded-pill">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0 table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Khách hàng</th>
                                <th>Xe đặt</th>
                                <th>Ngày tạo</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentBookings.forEach(booking => { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold"><%= booking.userId ? booking.userId.name : 'Ẩn danh' %></div>
                                    </td>
                                    <td><%= booking.carId ? booking.carId.model : 'Xe đã xóa' %></td>
                                    <td class="text-muted small"><%= new Date(booking.createdAt).toLocaleDateString('vi-VN') %></td>
                                    <td class="fw-bold"><%= booking.totalPrice ? booking.totalPrice.toLocaleString('vi-VN') : 0 %> đ</td>
                                    <td>
                                        <% if(booking.status === 'PENDING') { %>
                                            <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                        <% } else if(booking.status === 'CONFIRMED') { %>
                                            <span class="badge bg-primary">Đang thuê</span>
                                        <% } else if(booking.status === 'COMPLETED') { %>
                                            <span class="badge bg-success">Hoàn thành</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Đã hủy</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if(recentBookings.length === 0) { %>
                                <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có đơn hàng nào</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div> </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>