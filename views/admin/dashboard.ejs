<%- include('../partials/header') %>

<div class="container-fluid py-4 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark border-start border-4 border-warning ps-3">QUẢN TRỊ HỆ THỐNG</h2>
            <a href="/admin/cars/add" class="btn btn-warning fw-bold shadow-sm">
                <i class="fas fa-plus-circle me-2"></i>Thêm Xe Mới
            </a>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-3 bg-dark text-white rounded-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 text-uppercase">Tổng xe</h6>
                            <h2 class="fw-bold"><%= stats.totalCars %></h2>
                        </div>
                        <i class="fas fa-car fs-1 text-warning"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-3 bg-white rounded-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase">Đơn đặt</h6>
                            <h2 class="fw-bold text-dark"><%= stats.totalBookings %></h2>
                        </div>
                        <i class="fas fa-file-invoice fs-1 text-primary"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-3 bg-white rounded-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase">Doanh thu</h6>
                            <h2 class="fw-bold text-success"><%= stats.revenue.toLocaleString() %> đ</h2>
                        </div>
                        <i class="fas fa-coins fs-1 text-success"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-5">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="fw-bold mb-0">Danh sách xe hiện có</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Hình ảnh</th>
                                <th>Tên xe</th>
                                <th>Biển số</th>
                                <th>Giá/Ngày</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cars.forEach(car => { %>
                            <tr>
                                <td class="ps-4">
                                    <img src="<%= car.image %>" class="rounded-3 object-fit-cover" width="60" height="40" alt="">
                                </td>
                                <td class="fw-bold"><%= car.brand %> <%= car.model %></td>
                                <td><span class="badge bg-light text-dark border"><%= car.licensePlate %></span></td>
                                <td class="text-danger fw-bold"><%= car.pricePerDay.toLocaleString() %> đ</td>
                                <td>
                                    <% if(car.status === 'AVAILABLE') { %>
                                        <span class="badge bg-success bg-opacity-10 text-success">Sẵn sàng</span>
                                    <% } else if(car.status === 'RENTED') { %>
                                        <span class="badge bg-danger bg-opacity-10 text-danger">Đang thuê</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary">Bảo trì</span>
                                    <% } %>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/admin/cars/edit/<%= car._id %>" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                                    <a href="/admin/cars/delete/<%= car._id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn chắc chắn muốn xóa xe này?')"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
    </div>
</div>

<%- include('../partials/footer') %>