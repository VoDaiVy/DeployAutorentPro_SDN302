<%- include('../partials/header') %>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Quản Lý Đặt Xe</h2>
        <span class="badge bg-secondary">Trang <%= currentPage %> / <%= totalPages %></span>
    </div>
    
    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Khách Hàng</th>
                            <th>Xe</th>
                            <th>Lịch Trình</th>
                            <th>Tổng Tiền</th>
                            <th>Trạng Thái</th>
                            <th class="text-end pe-4">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% bookings.forEach(booking => { %>
                            <tr>
                                <td class="ps-4">
                                    <strong><%= booking.userId ? booking.userId.name : 'Ẩn danh' %></strong><br>
                                    <small class="text-muted"><%= booking.userId ? booking.userId.email : '' %></small>
                                </td>
                                <td>
                                    <% if (booking.carId) { %>
                                        <div class="fw-bold"><%= booking.carId.model %></div>
                                        <small><%= booking.carId.brand %></small>
                                    <% } else { %>
                                        <span class="text-danger">Xe đã xóa</span>
                                    <% } %>
                                </td>
                                <td>
                                    <%= new Date(booking.startDate).toLocaleDateString('vi-VN') %> - 
                                    <%= new Date(booking.endDate).toLocaleDateString('vi-VN') %>
                                </td>
                                <td class="fw-bold text-success">
                                    <%= booking.totalPrice ? booking.totalPrice.toLocaleString('vi-VN') : 0 %> đ
                                </td>
                                <td>
                                    <% if(booking.status === 'PENDING') { %>
                                        <span class="badge bg-warning text-dark">⏳ Chờ duyệt</span>
                                    <% } else if(booking.status === 'CONFIRMED') { %>
                                        <span class="badge bg-primary">🚗 Đang thuê</span>
                                    <% } else if(booking.status === 'COMPLETED') { %>
                                        <span class="badge bg-success">✅ Hoàn thành</span>
                                    <% } else { %>
                                        <span class="badge bg-danger">❌ Đã hủy</span>
                                    <% } %>
                                </td>
                                <td class="text-end pe-4">
                                    <form action="/admin/bookings/<%= booking._id %>" method="POST">
                                        <% if(booking.status === 'PENDING') { %>
                                            <button type="submit" name="status" value="CONFIRMED" class="btn btn-sm btn-success" onclick="return confirm('Duyệt đơn này?')">Duyệt</button>
                                            <button type="submit" name="status" value="REJECTED" class="btn btn-sm btn-outline-danger" onclick="return confirm('Hủy đơn này?')">Hủy</button>
                                        <% } else if(booking.status === 'CONFIRMED') { %>
                                            <button type="submit" name="status" value="COMPLETED" class="btn btn-sm btn-info text-white" onclick="return confirm('Khách đã trả xe?')">Trả xe</button>
                                        <% } %>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            
            <% if (totalPages > 1) { %>
            <div class="d-flex justify-content-center py-3 bg-light border-top">
                <nav aria-label="Page navigation">
                    <ul class="pagination mb-0">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="/admin/bookings?page=<%= currentPage - 1 %>">Previous</a>
                        </li>

                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link" href="/admin/bookings?page=<%= i %>"><%= i %></a>
                            </li>
                        <% } %>

                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="/admin/bookings?page=<%= currentPage + 1 %>">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
            <% } %>
            </div>
    </div>
</div>

<%- include('../partials/footer') %>