<%- include('../partials/header') %>

<div class="container d-flex justify-content-center align-items-center py-5" style="min-height: 80vh;">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="max-width: 900px; width: 100%;">
        <div class="row g-0">
            <div class="col-md-6 d-none d-md-block" style="background: url('https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?q=80&w=800&auto=format&fit=crop') center/cover no-repeat;">
                <div class="h-100 w-100" style="background: rgba(0,0,0,0.6);">
                    <div class="d-flex h-100 align-items-center justify-content-center text-white text-center p-4">
                        <div>
                            <h3 class="fw-bold mb-3">Tham gia cùng chúng tôi</h3>
                            <p>Tạo tài khoản để trải nghiệm dịch vụ thuê xe 5 sao.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 bg-white p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-dark">Đăng Ký</h2>
                    <p class="text-muted small">Tạo tài khoản mới hoàn toàn miễn phí</p>
                </div>

                <form action="/auth/register" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Họ và Tên</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-user text-muted"></i></span>
                            <input type="text" name="name" class="form-control bg-light border-0 py-2" placeholder="Nguyễn Văn A" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-envelope text-muted"></i></span>
                            <input type="email" name="email" class="form-control bg-light border-0 py-2" placeholder="name@example.com" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-lock text-muted"></i></span>
                            <input type="password" name="password" class="form-control bg-light border-0 py-2" placeholder="••••••••" required>
                        </div>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-dark fw-bold py-2 shadow-sm">
                            ĐĂNG KÝ
                        </button>
                    </div>

                    <div class="text-center">
                        <p class="small text-muted mb-0">Đã có tài khoản? 
                            <a href="/users/login" class="text-warning fw-bold text-decoration-none">Đăng nhập</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>