<%- include('../partials/header') %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="max-width: 900px; width: 100%;">
        <div class="row g-0">
            <div class="col-md-6 d-none d-md-block" style="background: url('https://images.unsplash.com/photo-1494976388531-d1058494cdd8?q=80&w=800&auto=format&fit=crop') center/cover no-repeat;">
                <div class="h-100 w-100" style="background: rgba(0,0,0,0.5);">
                    <div class="d-flex h-100 align-items-center justify-content-center text-white text-center p-4">
                        <div>
                            <h3 class="fw-bold mb-3">Chào mừng trở lại!</h3>
                            <p>Tiếp tục hành trình đẳng cấp cùng AutoRent Pro.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 bg-white p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-dark">Đăng Nhập</h2>
                    <p class="text-muted small">Nhập thông tin tài khoản của bạn</p>
                </div>

                <form action="/auth/login" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-envelope text-muted"></i></span>
                            <input type="email" name="email" class="form-control bg-light border-0 py-2" placeholder="name@example.com" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-lock text-muted"></i></span>
                            <input type="password" name="password" class="form-control bg-light border-0 py-2" placeholder="••••••••" required>
                        </div>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-warning fw-bold py-2 text-dark shadow-sm">
                            ĐĂNG NHẬP
                        </button>
                    </div>

                    <div class="text-center">
                        <p class="small text-muted mb-0">Chưa có tài khoản? 
                            <a href="/users/register" class="text-warning fw-bold text-decoration-none">Đăng ký ngay</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>