<%- include('../partials/header') %>

<div class="container py-5">
    <div class="text-center mb-5">
        <h6 class="text-warning fw-bold">BỘ SƯU TẬP</h6>
        <h2 class="fw-bold display-5">XE SẴN SÀNG</h2>
        <div class="mx-auto mt-3" style="width: 60px; height: 3px; background-color: var(--primary-color);"></div>
    </div>
    
    <div class="row g-4">
        <% if (!cars || cars.length === 0) { %>
            <div class="col-12 text-center">
                <div class="alert alert-secondary py-5">
                    <i class="fas fa-car-crash fa-3x mb-3 text-muted"></i>
                    <h5>Hiện tại chưa có xe nào khả dụng</h5>
                    <p>Vui lòng quay lại sau ít phút.</p>
                </div>
            </div>
        <% } else { %>
            <% cars.forEach(function(car) { %>
                <div class="col-md-4">
                    <div class="card card-custom h-100">
                        <div class="card-img-wrapper">
                            <img src="<%= car.image %>" 
                                 class="card-img-top" 
                                 alt="<%= car.model %>" 
                                 style="height: 220px; width: 100%; object-fit: cover;"
                                 onerror="this.src='https://via.placeholder.com/800x400?text=Xe+Dang+Cap+Nhat'"> 
                                 <div class="position-absolute top-0 end-0 m-3">
                                <% if(car.status === 'RENTED') { %>
                                    <span class="badge bg-danger shadow">ĐÃ THUÊ</span>
                                <% } else if(car.status === 'MAINTENANCE') { %>
                                    <span class="badge bg-secondary shadow">BẢO TRÌ</span>
                                <% } else { %>
                                    <span class="badge bg-success shadow">SẴN SÀNG</span>
                                <% } %>
                            </div>
                        </div>
                        
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="text-uppercase text-muted fw-bold"><%= car.brand %></small>
                                <small class="text-muted"><i class="fas fa-gas-pump me-1"></i> <%= car.fuelType || 'Xăng' %></small>
                            </div>
                            <h4 class="card-title fw-bold mb-3 text-truncate"><%= car.model %></h4>
                            
                            <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                                <div>
                                    <small class="text-muted d-block">Giá thuê ngày</small>
                                    <span class="text-danger fw-bold fs-5"><%= car.pricePerDay.toLocaleString('vi-VN') %> đ</span>
                                </div>
                                <a href="/cars/<%= car._id %>" class="btn btn-dark rounded-pill px-4">
                                    Chi tiết <i class="fas fa-arrow-right ms-1 text-warning"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>